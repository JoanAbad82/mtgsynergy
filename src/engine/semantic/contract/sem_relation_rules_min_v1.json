  "relation_kinds": {
    "produce": {
      "id": "produce",
      "label": "produce",
      "definition": "An effect explicitly yields a recognized action/resource.",
      "allowed_sources": ["effect"],
      "not_allowed_as": ["consume", "depend", "trigger", "guardedFollowUp", "contextOnly"]
    },
    "consume": {
      "id": "consume",
      "label": "consume",
      "definition": "A cost explicitly pays or gives up something to enable the effect.",
      "allowed_sources": ["cost"],
      "not_allowed_as": ["produce", "depend", "trigger", "guardedFollowUp", "contextOnly"]
    },
    "depend": {
      "id": "depend",
      "label": "depend",
      "definition": "A condition gates an effect without being a cost.",
      "allowed_sources": ["condition"],
      "not_allowed_as": ["produce", "consume", "trigger", "guardedFollowUp", "contextOnly"]
    },
    "trigger": {
      "id": "trigger",
      "label": "trigger",
      "definition": "A trigger_event activates the ability.",
      "allowed_sources": ["trigger_event"],
      "not_allowed_as": ["produce", "consume", "depend", "guardedFollowUp", "contextOnly"]
    },
    "guardedFollowUp": {
      "id": "guardedFollowUp",
      "label": "guardedFollowUp",
      "definition": "A follow-up effect happens only if a prior step succeeds.",
      "allowed_sources": ["guarded_follow_up"],
      "not_allowed_as": ["produce", "consume", "depend", "trigger", "contextOnly"]
    },
    "contextOnly": {
      "id": "contextOnly",
      "label": "contextOnly",
      "definition": "Contextual hint not supported by recognized text signals.",
      "allowed_sources": ["effect", "cost", "trigger_event", "condition", "guarded_follow_up"],
      "not_allowed_as": ["produce", "consume", "depend", "trigger", "guardedFollowUp"]
    }
  },
  "classification_rules": [
    {
      "rule_id": "RR_PRODUCE_FROM_EFFECT",
      "applies_when": "An effect explicitly yields a recognized action/resource in AbilityIR.",
      "classify_as": "produce",
      "notes": "Textual effect is the anchor; no inference."
    },
    {
      "rule_id": "RR_CONSUME_FROM_COST",
      "applies_when": "A cost precedes and enables an effect in AbilityIR.",
      "classify_as": "consume",
      "notes": "Only when cost is explicitly present."
    },
    {
      "rule_id": "RR_DEPEND_FROM_CONDITION",
      "applies_when": "A condition gates an effect without being a cost.",
      "classify_as": "depend",
      "notes": "Condition is textual and explicit."
    },
    {
      "rule_id": "RR_TRIGGER_FROM_EVENT",
      "applies_when": "A trigger_event activates the ability frame.",
      "classify_as": "trigger",
      "notes": "Trigger is an explicit event, not a condition."
    },
    {
      "rule_id": "RR_GUARDED_FOLLOW_UP",
      "applies_when": "guarded_follow_up exists and depends on a prior step.",
      "classify_as": "guardedFollowUp",
      "notes": "Reserved for later; null in base corpus."
    },
    {
      "rule_id": "RR_CONTEXT_ONLY_FALLBACK",
      "applies_when": "No explicit signal supports a relation.",
      "classify_as": "contextOnly",
      "notes": "Heuristic boundary; not a hard relation."
    }
  ],
